# ---- Database (Supabase) ----
# Pooled connection (pgBouncer, port 6543) — general queries
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — REQUIRED for SELECT ... FOR UPDATE slot locks
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ---- Meta WhatsApp Cloud API ----
# Webhook verify token (you choose any random string; set same in Meta dashboard)
VERIFY_TOKEN=change-me-random-string
# App secret (Meta App > Settings > Basic) — used to verify inbound webhook signatures
APP_SECRET=your_meta_app_secret

# ---- Server ----
PORT=3000
# Public base URL (Railway) — used in onboarding to print Razorpay webhook URL
PUBLIC_BASE_URL=https://your-app.up.railway.app

# ---- Booking rules ----
HOLD_MINUTES=10
LINK_EXPIRY_MINUTES=20      # Razorpay min is 15; reconciliation+refund guards the race, not link timing
REAPER_SECONDS=60
CANCEL_HOURS=4
STALE_MINUTES=30
MAX_DAILY_HOLDS=10
TZ=Asia/Kolkata

# ---- Admin dashboard ----
ADMIN_PASSWORD=set-a-strong-password
ADMIN_SECRET=random-string-for-signing-the-session-cookie
# set to false only for local http testing
COOKIE_SECURE=true
