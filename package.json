{
  "name": "turf-whatsapp-bot",
  "version": "1.0.0",
  "description": "Multi-tenant WhatsApp turf booking bot (Meta Cloud API + Razorpay)",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "db:schema": "node scripts/run-sql.js db/schema.sql",
    "db:seed": "node scripts/run-sql.js db/seed.sql",
    "onboard": "node scripts/onboard-tenant.js",
    "gen-slots": "node scripts/generate-slots.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "razorpay": "^2.9.4"
  }
}
